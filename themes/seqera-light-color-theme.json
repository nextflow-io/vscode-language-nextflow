  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#545555",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#065647"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#0A9B7D"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#0A9B7D"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#065647"
      }
    },
    {
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": {
        "foreground": "#0451A5"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#160F26"
      }
    },
    {
      "scope": ["keyword.nextflow"],
      "settings": {
        "foreground": "#0A9B7D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.function.nextflow"],
      "settings": {
        "foreground": "#065647",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["constant.block.nextflow"],
      "settings": {
        "foreground": "#0DC09D"
      }
    },
    {
      "scope": ["process.nextflow", "workflow.nextflow", "record.nextflow", "params.nextflow", "output.nextflow"],
      "settings": {
        "foreground": "#160F26"
      }
    },
    {
      "scope": ["invalid.illegal.level.error.nextflow-log"],
      "settings": {
        "foreground": "#C72E0F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated.level.warn.nextflow-log"],
      "settings": {
        "foreground": "#B58900",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword.other.level.info.nextflow-log"],
      "settings": {
        "foreground": "#0A9B7D"
      }
    },
    {
      "scope": ["keyword.other.level.debug.nextflow-log", "keyword.other.level.trace.nextflow-log"],
      "settings": {
        "foreground": "#BABCBD",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.name.function.process.nextflow-log"],
      "settings": {
        "foreground": "#065647"
      }
    },
    {
      "scope": ["constant.other.timestamp.nextflow-log"],
      "settings": {
        "foreground": "#BABCBD"
      }
    },
    {
      "scope": ["entity.name.type.exception.nextflow-log"],
      "settings": {
        "foreground": "#C72E0F"
      }
    }
  ]
}
